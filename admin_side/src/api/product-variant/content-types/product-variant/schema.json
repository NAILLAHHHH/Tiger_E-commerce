{
  "kind": "collectionType",
  "collectionName": "product_variants",
  "info": {
    "singularName": "product-variant",
    "pluralName": "product-variants",
    "displayName": "Product Variant",
    "description": "Size and color SKU with stock"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "sku": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "size": {
      "type": "string",
      "required": true
    },
    "color": {
      "type": "string",
      "required": true
    },
    "color_hex": {
      "type": "string"
    },
    "stock_quantity": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "product": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::product.product",
      "inversedBy": "variants"
    }
  }
}
