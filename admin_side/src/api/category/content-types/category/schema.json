{
  "kind": "collectionType",
  "collectionName": "categories",
  "info": {
    "singularName": "category",
    "pluralName": "categories",
    "displayName": "Category",
    "description": "Shop sections — T-Shirts, Hoodies, Pants, etc."
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "description": "Name customers see, e.g. T-Shirts"
    },
    "link_name": {
      "type": "uid",
      "targetField": "name",
      "required": true,
      "description": "Filled in automatically — used for the website link",
      "pluginOptions": {
        "content-manager": {
          "visible": false
        }
      }
    },
    "photo": {
      "type": "string",
      "description": "Picture for this category, e.g. /products/01-grey-zip-hoodie.png"
    },
    "list_position": {
      "type": "integer",
      "default": 0,
      "description": "Order on the website (1 = show first, 2 = second, etc.)"
    },
    "products": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::product.product",
      "mappedBy": "category"
    }
  }
}
